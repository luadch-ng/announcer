# Compiled Lua sources
luac.out

# luarocks build files
*.src.rock
*.zip
*.tar.gz

# Object files
*.o
*.os
*.ko
*.obj
*.elf

# Precompiled Headers
*.gch
*.pch

# Libraries (intermediates - bundled lib/**.dll is whitelisted below)
*.lib
*.a
*.la
*.lo
*.def
*.exp

# Shared objects (inc. Windows DLLs) - bundled lib/ is whitelisted below
*.dll
*.so
*.so.*
*.dylib

# Executables
*.exe
*.out
*.app
*.i*86
*.x86_64
*.hex

# Runtime data (per-install; never commit)
log/*.txt
certs/*.pem
core/status.lua
# bot PID/CID - generated on first run by core/adc.lua, IS the bot's tiger-hash secret
cfg/id.lua

# Bundled binary deps (whitelisted - shipped with the repo)
# Phase 2 swapped most C-extension .dlls to CMake build artefacts; the
# only committed binaries left are lib/lfs_wx/lfs.dll (still Lua-5.1,
# Phase 3 GUI rework will replace) and the GUI resource bundles under
# lib/ressources/ (Phase 2 PR-E will replace with PNG-loaded resources).
!lib/lfs_wx/**/*.dll
!lib/ressources/**/*.dll

# CMake build directory (build outputs are NOT committed; build locally
# from source via the in-tree CMake pipeline - see README and BUILDING.md)
build/

# Frontend GUI freeze artefacts (build outputs - never commit)
frontends/gui/*.exe
frontends/gui/Announcer.exe
