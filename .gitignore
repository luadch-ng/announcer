# Compiled Lua sources
luac.out

# luarocks build files
*.src.rock
*.zip
*.tar.gz

# Object files
*.o
*.os
*.ko
*.obj
*.elf

# Precompiled Headers
*.gch
*.pch

# Libraries (intermediates - bundled lib/**.dll is whitelisted below)
*.lib
*.a
*.la
*.lo
*.def
*.exp

# Shared objects (inc. Windows DLLs) - bundled lib/ is whitelisted below
*.dll
*.so
*.so.*
*.dylib

# Executables
*.exe
*.out
*.app
*.i*86
*.x86_64
*.hex

# Runtime data (per-install; never commit)
log/*.txt
certs/*.pem
core/status.lua
cfg/id.lua  # bot PID/CID - generated on first run by core/adc.lua, secret

# Bundled binary deps (whitelisted - upstream client ships them with the repo)
!lib/**/*.dll
!lib/**/*.so
!lib/**/*.so.*
!lib/**/*.dylib
!lib/ressources/**/*.dll

# Frontend GUI freeze artefacts (build outputs - never commit)
frontends/gui/*.exe
frontends/gui/Announcer.exe
